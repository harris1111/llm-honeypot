generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST
  VIEWER
}

enum NodeStatus {
  PENDING
  ONLINE
  OFFLINE
  DISABLED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  role         UserRole      @default(VIEWER)
  totpSecret   String?
  totpEnabled  Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  auditLogs    AuditLog[]
  sessions     UserSession[]
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  refreshTokenHash String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Persona {
  id          String   @id @default(cuid())
  name        String   @unique
  preset      String?
  identity    Json
  hardware    Json
  models      Json
  services    Json
  configFiles Json
  timing      Json
  credentials Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  nodes       Node[]
}

model Node {
  id            String            @id @default(cuid())
  name          String
  hostname      String?
  publicIp      String?
  nodeKeyHash   String            @unique
  nodeKeyPrefix String            @unique
  status        NodeStatus        @default(PENDING)
  lastHeartbeat DateTime?
  personaId     String?
  config        Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  persona       Persona?          @relation(fields: [personaId], references: [id])
  budgets       BudgetEntry[]
  requests      CapturedRequest[]
  sessions      HoneypotSession[]

  @@index([status, lastHeartbeat])
}

model Actor {
  id                String            @id @default(cuid())
  label             String?
  headerFingerprint String?
  tlsFingerprints   String[]
  userAgents        String[]
  firstSeen         DateTime          @default(now())
  lastSeen          DateTime          @default(now())
  sessionCount      Int               @default(0)
  mergedFrom        String[]
  sessions          HoneypotSession[]
}

model HoneypotSession {
  id             String            @id @default(cuid())
  nodeId         String
  sourceIp       String
  userAgent      String?
  service        String
  classification String?
  startedAt      DateTime          @default(now())
  endedAt        DateTime?
  requestCount   Int               @default(0)
  actorId        String?
  archivedAt     DateTime?
  archiveManifestId String?
  actor          Actor?            @relation(fields: [actorId], references: [id], onDelete: SetNull)
  archiveManifest ArchiveManifest? @relation(fields: [archiveManifestId], references: [id], onDelete: SetNull)
  node           Node              @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  requests       CapturedRequest[]

  @@index([actorId])
  @@index([archiveManifestId])
  @@index([archivedAt])
  @@index([nodeId, startedAt])
  @@index([sourceIp])
}

model ArchiveManifest {
  id                String            @id @default(cuid())
  archiveSizeBytes  Int
  bucket            String
  createdAt         DateTime          @default(now())
  format            String            @default("jsonl.gz")
  periodEnd         DateTime
  periodStart       DateTime
  requestCount      Int
  sessionCount      Int
  sessions          HoneypotSession[]
  storageKey        String            @unique

  @@index([createdAt])
}

model CapturedRequest {
  id               String           @id @default(cuid())
  timestamp        DateTime         @default(now())
  nodeId           String
  sessionId        String?
  sourceIp         String
  sourcePort       Int?
  protocol         String
  service          String
  method           String
  path             String?
  headers          Json?
  headerHash       String?
  userAgent        String?
  requestBody      Json?
  responseCode     Int?
  responseBody     Json?
  responseStrategy String?
  tlsFingerprint   String?
  classification   String?
  geo              Json?
  createdAt        DateTime         @default(now())
  node             Node             @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  session          HoneypotSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([classification])
  @@index([nodeId, timestamp])
  @@index([nodeId, service, timestamp])
  @@index([service])
  @@index([sessionId])
  @@index([sourceIp])
}

model ResponseTemplate {
  id            String   @id @default(cuid())
  category      String
  subcategory   String?
  promptHash    String?  @unique
  promptText    String
  responseText  String
  modelName     String?
  keywords      String[]
  burned        Boolean  @default(false)
  autoGenerated Boolean  @default(false)
  approved      Boolean  @default(true)
  usageCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([burned, approved])
  @@index([category])
}

model AlertRule {
  id          String     @id @default(cuid())
  name        String
  conditions  Json
  severity    String
  channels    String[]
  cooldownMin Int        @default(5)
  enabled     Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  logs        AlertLog[]
}

model AlertLog {
  id        String    @id @default(cuid())
  ruleId    String
  payload   Json
  channel   String
  sentAt    DateTime  @default(now())
  success   Boolean   @default(true)
  rule      AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
}

model IpEnrichment {
  ip            String   @id
  country       String?
  city          String?
  region        String?
  asn           String?
  org           String?
  isp           String?
  ispType       String?
  reverseDns    String?
  isKnownBad    Boolean  @default(false)
  abuseScore    Float?
  isTor         Boolean  @default(false)
  isVpn         Boolean  @default(false)
  cloudProvider String?
  enrichedAt    DateTime @default(now())
  expiresAt     DateTime
}

model BudgetEntry {
  id            String   @id @default(cuid())
  nodeId        String?
  month         String
  tokensSent    Int      @default(0)
  tokensRecv    Int      @default(0)
  estimatedCost Float    @default(0)
  limitCost     Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  node          Node?    @relation(fields: [nodeId], references: [id], onDelete: SetNull)

  @@unique([nodeId, month])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  target    String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([userId, createdAt])
}