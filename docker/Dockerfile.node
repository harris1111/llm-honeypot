FROM node:22-alpine AS builder

RUN corepack enable
WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json tsconfig.base.json ./
COPY apps ./apps
COPY packages ./packages
COPY templates ./templates

RUN pnpm install --frozen-lockfile
RUN pnpm --filter @llmtrap/node... build

FROM node:22-alpine AS runner

RUN addgroup -S llmtrap && adduser -S llmtrap -G llmtrap && mkdir -p /home/llmtrap/.llmtrap-runtime && chown -R llmtrap:llmtrap /home/llmtrap
WORKDIR /app

COPY --from=builder /app/apps/node/dist ./apps/node/dist
COPY --from=builder /app/apps/node/node_modules ./apps/node/node_modules
COPY --from=builder /app/apps/node/package.json ./apps/node/package.json
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages ./packages
COPY --from=builder /app/templates ./templates

ENV NODE_ENV=production
EXPOSE 11434 1234 3001 3002 3003 5000 6333 7474 8000 8080 8081 8082 8083 8084 8085 8086 8123 8989 9000 9090 9696 10021 10022 10023 10025 10445 1053 10587 19530 32400
USER llmtrap

CMD ["node", "apps/node/dist/main.js"]