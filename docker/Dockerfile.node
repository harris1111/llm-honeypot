FROM node:22-alpine AS builder

RUN corepack enable
WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json tsconfig.base.json ./
COPY apps ./apps
COPY packages ./packages
COPY templates ./templates

RUN pnpm install --frozen-lockfile
RUN pnpm --filter @llmtrap/node... build

FROM node:22-alpine AS runner

RUN addgroup -S llmtrap && adduser -S llmtrap -G llmtrap
WORKDIR /app

COPY --from=builder /app/apps/node/dist ./apps/node/dist
COPY --from=builder /app/apps/node/node_modules ./apps/node/node_modules
COPY --from=builder /app/apps/node/package.json ./apps/node/package.json
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages ./packages
COPY --from=builder /app/templates ./templates

ENV NODE_ENV=production
EXPOSE 11434 1234 5000 8000 8080 8081 8082 8083 8084
USER llmtrap

CMD ["node", "apps/node/dist/main.js"]