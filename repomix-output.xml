    build:
      context: ..
      dockerfile: docker/Dockerfile.worker
    environment:
      DATABASE_URL: postgresql://${POSTGRES_USER:-llmtrap}:${POSTGRES_PASSWORD:-llmtrap}@postgres:5432/${POSTGRES_DB:-llmtrap}
      REDIS_URL: redis://redis:6379
      WORKER_CONCURRENCY: 4
